# ============================================
# Bot PM/CEO — Variables de Entorno
# Copia este archivo como .env y llena los valores
# cp .env.example .env
# ============================================

# Nombre del bot (aparece en las respuestas)
BOT_NAME=Carlo

# PostgreSQL (Supabase o local)
# Local: postgresql://postgres:postgres@localhost:5432/doctoc_bot
# Supabase: postgresql://postgres:[pwd]@db.[project].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/doctoc_bot

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxx

# Kapso WhatsApp
KAPSO_API_KEY=xxx
KAPSO_PHONE_NUMBER_ID=xxx
KAPSO_WEBHOOK_SECRET=xxx

# Airtable (sync push para Kanban)
AIRTABLE_API_KEY=patXXX
AIRTABLE_BASE_ID=appXXX

# WhatsApp destinos fijos
WHATSAPP_PM=+51999111222
WHATSAPP_CEO=+51999333444

# API REST auth
API_KEY_ADMIN=tu-api-key-secreta-aqui

# CORS (en prod: dominio del frontend, separados por coma)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Observabilidad (opcional)
LOGFIRE_TOKEN=

# Entorno (LOCAL, DEV, PROD)
SETUP=LOCAL
